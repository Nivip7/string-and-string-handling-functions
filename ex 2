1.VALID PASSWORD:
>NO SPACE
>ATLEAST ONE DIGIT
>LENGTH BETWEEN 8-15
>ATLEADT ONE UPPER AND LOWERCASE
>ATLEAST ONE SPECIAL CHARACTER


p=input("Password:")
if(8<=len(p)<=15 and
   any(ch.islower() for ch in p) and
   any(ch.isupper() for ch in p) and
   any(ch.isdigit() for ch in p) and
   any(not ch.isalnum() for ch in p) and
   not any(ch.isspace() for ch in p)):
    print("your password is valid!!!")
else:
    print("invalid password!!!!")


2.TO REPEAT A LETTER


s=input("Enter a string:")
result=""
for i in range (0,len(s),2):
    char=s[i]
    n=int(s[i+1])
    result+=char*n
print("output:",result)


